#!/usr/bin/env python3
"""unstage.py  —  Python port of unstage.js

Unstage specific staged lines (split a staged hunk) non-interactively, by
rebuilding a subset patch and reverse-applying it to the index:
  git diff --cached -- <file>  |  filter  |  git apply --cached -R --recount

Usage:
  python3 unstage.py [--dry-run] <file> <spec> [<spec> ...]

Flags (in addition to the positional args):
  --dry-run    print the computed patch instead of applying it
  -h, --help   show this help

Specs — a range of NEW-file (working/index) line numbers, i.e. the line
numbers your editor's gutter shows. A range UNDOES ANY staged change it
covers, with no need to say "add" or "delete":
  N        single line
  N-M      range N..M inclusive
  -N       from line 1 to N
  N-       from line N to end

Semantics within a range:
  - a staged addition (+) on a covered new-file line     -> unstaged
  - a staged deletion (-) at a covered new-file position -> re-included
  - a modified line (a -/+ pair) shares one new-file number, so a single
    range value undoes both halves at once.
A deletion has no new-file line of its own; it is matched by the new-file
position it was removed from (the gap), so e.g. deleting the last line is
covered by a range reaching one past the final line (use "N-").
"""
import subprocess
import sys


def usage():
    sys.stderr.write(
        "Usage: python3 unstage.py [--dry-run] <file> <spec> [<spec> ...]\n"
        "  spec: N | N-M | -N | N-   (NEW-file line numbers; undoes any staged change in range)\n"
    )


def parse_specs(specs):
    """Return a list of intervals (lo, hi); hi=None means open-ended."""
    intervals = []
    for s in specs:
        s = s.strip()
        if "-" in s:
            lo, hi = s.split("-", 1)
            lo = int(lo) if lo else 1            # "-N" -> 1..N
            hi = int(hi) if hi else None         # "N-" -> N..end
        else:
            lo = hi = int(s)                     # "N"  -> N..N
        intervals.append((lo, hi))
    return intervals


def selected(n, intervals):
    return any(lo <= n and (hi is None or n <= hi) for lo, hi in intervals)


def build_patch(diff, intervals):
    """Rebuild the subset patch from `git diff --cached` output.

    Both additions and deletions are matched against the NEW-file line counter:
      '+' uses its own new-file line number;
      '-' uses the current new-file position (the gap it was removed from).
    """
    lines = diff.split("\n")
    if lines and lines[-1] == "":
        lines.pop()                              # mirror splitlines() trailing handling
    out = []
    new_ln = 0
    in_hunk = False
    for line in lines:
        if (line.startswith("diff ") or line.startswith("index ")
                or line.startswith("--- ") or line.startswith("+++ ")):
            out.append(line); continue          # file headers
        if line.startswith("@@"):
            out.append(line)                     # --recount fixes the numbers
            # @@ -old_start,old_len +new_start,new_len @@  -> seed new-file counter
            seg = line.split("@@")[1].strip()
            parts = seg.split(" ")
            new_ln = int(parts[1][1:].split(",")[0])  # strip leading '+'
            in_hunk = True; continue
        if not in_hunk:
            out.append(line); continue           # extended headers (mode/rename/etc.)
        tag = line[:1]
        text = line[1:]
        if tag == " ":                           # context: present on both sides
            out.append(line); new_ln += 1
        elif tag == "+":                          # addition: index side only
            out.append(line if selected(new_ln, intervals) else " " + text)
            new_ln += 1
        elif tag == "-":                          # deletion: matched by new-file position
            if selected(new_ln, intervals):
                out.append(line)                 # keep -> reverse-apply re-includes it
            # else: drop it (stays staged; not present in index, can't be context)
            # new_ln is NOT advanced: a deletion occupies no new-file line.
        else:
            out.append(line)                     # "\ No newline at end of file", etc.
    return "\n".join(out) + "\n"


def parse_args(argv):
    """Long flags + -h are flags; everything else (incl. "-N" specs) is positional."""
    dry_run = False
    positional = []
    for a in argv:
        if a == "--dry-run":
            dry_run = True
        elif a in ("-h", "--help"):
            usage(); sys.exit(0)
        elif a == "--":
            pass                                 # end-of-flags separator
        elif a.startswith("--"):
            sys.stderr.write("Unknown flag: " + a + "\n"); usage(); sys.exit(2)
        else:
            positional.append(a)                 # "-10", "80-", "10-20", filename, ...
    return dry_run, positional


def run_git(git_args, input_text=None):
    return subprocess.run(
        ["git"] + git_args, input=input_text,
        capture_output=True, text=True, check=True,
    ).stdout


def main():
    dry_run, positional = parse_args(sys.argv[1:])
    if len(positional) < 2:
        usage(); sys.exit(2)
    file = positional[0]
    intervals = parse_specs(positional[1:])

    try:
        diff = run_git(["diff", "--cached", "--", file])
    except subprocess.CalledProcessError as e:
        sys.stderr.write("git diff failed: " + (e.stderr or "") + "\n"); sys.exit(1)

    if not diff.strip():
        sys.stderr.write("No staged changes for " + file + "\n"); sys.exit(1)

    patch = build_patch(diff, intervals)
    if dry_run:
        sys.stdout.write(patch); return

    try:
        run_git(["apply", "--cached", "-R", "--recount"], patch)
    except subprocess.CalledProcessError as e:
        sys.stderr.write("git apply failed: " + (e.stderr or "") + "\n"); sys.exit(1)
    sys.stderr.write("Unstaged selected lines from " + file + ".\n")


if __name__ == "__main__":
    main()
