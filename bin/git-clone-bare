#!/usr/bin/env bash

[[ -v debug ]] && set -x

# clone the repo
git clone --bare "$@"

# return if repo was not created
if [ "$?" -ne 0 ]; then
  exit $?
fi

# extract directory name if not given as second argument
if [ -n "$2" ]; then
  dirrepo="$2"
else
  dirrepo="${1##*/}"
  dirrepo="${dirrepo%.*}"
fi

# Avoid ".git" when cloning repos
if [ -d "${dirrepo}.git" ]; then
  mv "${dirrepo}.git" "$dirrepo" || exit 1
fi

# Setup the bare repository
pushd "$dirrepo" || exit
# Add git remote config
# Ref: https://morgan.cugerone.com/blog/workarounds-to-git-worktree-using-bare-repository-and-cannot-fetch-remote-branches
git config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
git fetch origin
popd || exit

